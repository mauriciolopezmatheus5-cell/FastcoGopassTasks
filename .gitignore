# ──────────────────────────────────────────────────
#  GopassTasks — Root .gitignore
#  Covers monorepo: gopasstasks-api/ + gopasstasks-web/
# ──────────────────────────────────────────────────

# ── Node.js ──────────────────────────────────────
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*
.pnp
.pnp.js

# ── Build outputs ────────────────────────────────
dist/
dist-ssr/
build/
out/
gopasstasks-api/dist/
gopasstasks-web/dist/

# ── Testing & Coverage ───────────────────────────
coverage/
*.lcov
.nyc_output/
test-results/
playwright-report/

# ── Environment files ────────────────────────────
# Nunca commitear archivos con credenciales reales
.env
.env.local
.env.development
.env.staging
.env.production
.env.test
.env.docker
# Sí se commitean los ejemplos/plantillas
!.env.example
!.env.docker.example
!*.env.example

# ── Docker ───────────────────────────────────────
# Los volúmenes de Docker generados localmente
.docker-volumes/

# ── Prisma ───────────────────────────────────────
# Las migraciones SÍ se commitean (control de versiones del esquema)
# Solo ignorar el .env de prisma si existe separado
gopasstasks-api/prisma/.env

# ── Logs ─────────────────────────────────────────
logs/
*.log
*.log.*

# ── IDEs y Editores ──────────────────────────────
.vscode/
!.vscode/extensions.json
.idea/
*.iml
.project
.classpath
.c9/
*.launch
.settings/
*.sublime-workspace

# ── macOS ────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V8
.Trashes
ehthumbs.db
Thumbs.db

# ── Windows ──────────────────────────────────────
desktop.ini
$RECYCLE.BIN/
*.cab
*.msi
*.msix
*.msm
*.msp

# ── Linux ────────────────────────────────────────
*~
.nfs*

# ── Vite ─────────────────────────────────────────
*.local

# ── TypeScript ───────────────────────────────────
*.tsbuildinfo

# ── Optional caches ──────────────────────────────
.eslintcache
.stylelintcache
.parcel-cache
.turbo/
.cache/
