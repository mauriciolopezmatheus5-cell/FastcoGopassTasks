# .env.docker.example — Plantilla de variables de entorno para Docker local
# Copia este archivo como .env.docker y configura tus valores:
#   cp .env.docker.example .env.docker
#
# En producción (AWS ECS), estas variables se inyectan desde AWS Secrets Manager.
# NUNCA commitear .env.docker al repositorio.

# ── PostgreSQL ──────────────────────────────────────────────────
POSTGRES_DB=gopasstasks
POSTGRES_USER=gopass
POSTGRES_PASSWORD=change_me_in_production

# ── Redis ───────────────────────────────────────────────────────
REDIS_PASSWORD=change_me_in_production

# ── JWT (mínimo 32 caracteres) ──────────────────────────────────
JWT_SECRET=change_me_in_production_minimum_32_chars

# ── URLs (para docker-compose.prod.yml) ─────────────────────────
DATABASE_URL=postgresql://gopass:change_me@postgres:5432/gopasstasks
FRONTEND_URL=http://localhost:5173
VITE_API_URL=http://localhost:3000/api
